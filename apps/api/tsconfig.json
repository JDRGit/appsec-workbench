{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "module": "CommonJS",
    "target": "ES2020",
    "moduleResolution": "Node",
    "noEmit": false,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "paths": {
      "@prisma/client": ["node_modules/.prisma/client"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
