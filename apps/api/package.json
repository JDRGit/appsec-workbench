{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "API_DATABASE_URL=file:./dev.db PORT=3000 ts-node --project tsconfig.json src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "API_DATABASE_URL=file:./dev.db PORT=3000 node dist/main.js",
    "start:render": "node scripts/ensure-db.mjs && node dist/main.js",
    "db:generate": "API_DATABASE_URL=file:./dev.db prisma generate --schema prisma/schema.prisma",
    "db:seed": "API_DATABASE_URL=file:./dev.db node prisma/seed.mjs",
    "db:setup": "npm run db:generate && npm run db:seed"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.8",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@prisma/client": "^6.6.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^6.6.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
